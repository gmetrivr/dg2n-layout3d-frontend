# Supabase configuration                                                                                                                                                                            
# Copy this file to .env.local and fill in your actual credentials
                                                                                                                                                                                                      
# IMPORTANT: Do NOT point this directly at *.supabase.co                         
# Jio and JioFiber ISPs silently block supabase.co at the network level, causing
# all Supabase operations (auth, database, storage) to time out for Indian users
# on those networks. Route traffic through a Cloudflare Worker proxy on your own
# domain instead — the Supabase JS SDK will send all requests through it automatically.
# Setup guide: https://www.metefy.com/blog/fix-supabase-down-on-jio-and-jiofiber-by-hiding-supabase-behind-your-own-domain-free-tier
VITE_SUPABASE_URL=https://your-backend.dg2n.com/supabase 
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Storage bucket name (defaults to 'store-archives' if not set)
# VITE_SUPABASE_BUCKET=store-archives

# Optional: API base URL for Make Live endpoint
# Leave empty/unset to use relative URLs (which go through Vite proxy in dev)
# Set to full URL for production deployment (e.g., https://stockflow-core.dg2n.com)
# VITE_API_URL=https://stockflow-core.rc.dg2n.com  # Commented out to use Vite proxy

# Backend API URL (for storage operations)
VITE_BACKEND_API_URL=http://localhost:4260  # Local development
# VITE_BACKEND_API_URL=https://dg2n-layout3d-backend.rc.dg2n.com  # Production

# SCRIPT_EMAIL and SCRIPT_PASSWORD are used by Node scripts for authentication with Supabase
SCRIPT_EMAIL=your@mail.com
SCRIPT_PASSWORD=password